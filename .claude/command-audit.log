swipe_up() {
  local udid="$1"
  # Get device info for screen dimensions
  # Use AppleScript to simulate keyboard "down arrow" which triggers snap scroll
  # Actually we'll use simctl's key send for page down
  xcrun simctl io "$udid" sendkey 0x7D 2>/dev/null  # down arrow
