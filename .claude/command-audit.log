capture_device() {
  local udid="$1"
  local name="$2"
  
  for num_section in "01:hero:" "02:ingestion:ingestion" "03:intel:intel" "04:fusion:fusion" "05:tactical-bim:tactical-bim" "06:site-docs:site-docs"; do
