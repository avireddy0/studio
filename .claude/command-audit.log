    local label=$(echo "$num_section" | cut -d: -f2)
    local param=$(echo "$num_section" | cut -d: -f3)
    
    xcrun simctl terminate "$udid" com.apple.mobilesafari 2>/dev/null || true
    sleep 1
    
    if [ -z "$param" ]; then
      local page_url="http://localhost:9002"
    else
      local page_url="http://localhost:9002/?s=${param}"
    fi
    
    xcrun simctl launch "$udid" com.apple.mobilesafari 2>/dev/null
    sleep 1
    xcrun simctl openurl "$udid" "$page_url" 2>/dev/null
    sleep 5
    
    xcrun simctl io "$udid" screenshot "/tmp/studio-responsive/${num}_${label}_${name}.png" 2>/dev/null
    
    local http_code=$(curl -s -o /dev/null -w "%{http_code}" http://localhost:9002 2>/dev/null)
    if [ "$http_code" != "200" ]; then
      echo "WARNING: Server returned $http_code after ${name}/${label}, waiting..."
      sleep 3
    fi
    echo "  ${num}_${label} done"
  done
  echo "Done: $name"
}

