  xcrun simctl io "$IPHONE_PRO" screenshot "/tmp/studio-responsive/${section}_iphone16pro.png" 2>/dev/null &
  xcrun simctl io "$IPAD" screenshot "/tmp/studio-responsive/${section}_ipadair11.png" 2>/dev/null &
  wait
